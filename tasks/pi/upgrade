#!/usr/bin/env bash
#MISE description="Upgrade pi to the latest npm release and rebuild the image"
set -euo pipefail

PI_IMAGE="pi-less-yolo:latest"
DOCKERFILE="${MISE_TASK_DIR}/../../Dockerfile"

docker image inspect "${PI_IMAGE}" > /dev/null 2>&1 || {
  echo "error: image not found — run: mise run pi:build" >&2
  exit 1
}

CURRENT=$(grep '^ARG PI_VERSION=' "${DOCKERFILE}" | cut -d'=' -f2)
LATEST=$(docker run --rm --entrypoint npm "${PI_IMAGE}" view @mariozechner/pi-coding-agent version)

if [[ "${CURRENT}" == "${LATEST}" ]]; then
  echo "Already at latest pi version: ${CURRENT}"
  exit 0
fi

echo "Upgrading pi: ${CURRENT} → ${LATEST}"

# perl -pi -e is cross-platform (macOS and Linux); avoids sed -i / sed -i ''
# incompatibility.
perl -pi -e "s/^ARG PI_VERSION=.*/ARG PI_VERSION=${LATEST}/" "${DOCKERFILE}"

mise run pi:build
